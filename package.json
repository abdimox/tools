{
  "name": "loho-xhs-ai-workbench",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["client", "server", "worker"],
  "scripts": {
    "dev": "npm run dev -w client",
    "dev:api": "wrangler dev --port 8788 --persist-to .wrangler/state",
    "dev:legacy": "concurrently --names server,client --prefix-colors blue,magenta \"npm:dev -w server\" \"npm:dev -w client\"",
    "db:local": "wrangler d1 migrations apply DB --local --persist-to .wrangler/state",
    "build": "npm run build -w client",
    "sync:knowledge": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/sync-knowledge.ps1 -Source \"D:\\agent\\chengzhang\\我的第二大脑\\06_小红书运营\\Photobooth运营知识库\"",
    "test": "npm run build -w client",
    "start": "npm run preview -w client -- --host 127.0.0.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
